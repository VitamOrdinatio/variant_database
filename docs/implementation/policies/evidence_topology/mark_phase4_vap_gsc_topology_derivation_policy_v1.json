    "normalization_rules": {
      "trim_whitespace": true,
      "empty_string_token": "__EMPTY__",
      "null_token": "__NULL__",
      "sort_multivalue_fields": true,
      "sort_members_by_stable_identifier": true,
      "sort_basis_components_by_stable_identifier": true
    },
    "v1_expansion_rule": "Do not hash expanded source identity values. Use source_identity_set_id references for source-identity-set-derived relationships."
  },
